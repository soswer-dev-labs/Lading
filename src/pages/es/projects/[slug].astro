---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer';
import { translations } from '../../../data/translations';

type ProjectDetail = {
  headline: string;
  purpose: string;
  overview: string;
  impactTitle: string;
  impact: string[];
  aboutTitle?: string;
  about?: string[];
  galleryTitle?: string;
};

type AssetImage = {
  src: string;
};

export function getStaticPaths() {
  return translations.es.projectsPage.items.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const content = translations.es;
const project = content.projectsPage.items.find((item) => item.slug === slug);
const slugKey = slug as keyof typeof content.projectDetails;
const details = content.projectDetails[slugKey] as ProjectDetail | undefined;

if (!project || !details) {
  throw new Error(`Project not found: ${slug}`);
}

const mySpaceImageModules = import.meta.glob('../../../assets/img/my_space/*.{png,jpg,jpeg,webp,avif}', {
  eager: true,
  import: 'default',
});

const keepDmImageModules = import.meta.glob('../../../assets/img/keepdm/*.{png,jpg,jpeg,webp,avif}', {
  eager: true,
  import: 'default',
});

const wLunaImageModules = import.meta.glob('../../../assets/img/W-luna/*.{png,jpg,jpeg,webp,avif,svg}', {
  eager: true,
  import: 'default',
});

const facturacionImageModules = import.meta.glob('../../../assets/img/facturacion/*.{png,jpg,jpeg,webp,avif,svg}', {
  eager: true,
  import: 'default',
});

const mySpaceImageOrder = [
  'my-space-storefront.webp',
  'my-space-logo_.webp',
  'my-space-page_mockup.webp',
  'my-space-services.webp',
  'my-space-catalog-sections.webp',
  'my-space-featured-products.webp',
];

const mySpaceCaptions: Record<string, string> = {
  'my-space-storefront.webp': 'Foto de la papeleria fisica, mostrando la presencia de marca y punto de atencion.',
  'my-space-logo_.webp': 'Concepto del logo: un simbolo tipo mascota que fusiona la identidad de papeleria con el espiritu de cafe internet de barrio, para transmitir cercania y recordacion de marca desde el primer vistazo.',
  'my-space-page_mockup.webp': 'Mockup principal de escritorio: el hero de inicio fue disenado para generar confianza, destacar categorias clave y llevar al usuario de exploracion a compra en pocos clics.',
  'my-space-services.webp': 'Seccion de servicios con impresion, internet, venta por catalogo y llamadas.',
  'my-space-catalog-sections.webp': 'Secciones del catalogo para papeleria, moda por catalogo y hogar.',
  'my-space-featured-products.webp': 'Modulo de productos destacados orientado a mejorar descubrimiento y conversion.',
};

const mySpaceImages = Object.entries(mySpaceImageModules)
  .map(([path, src]) => {
    const image = src as string | AssetImage;
    return {
      path,
      src: typeof image === 'string' ? image : image.src,
    };
  })
  .sort((a, b) => {
    const aIndex = mySpaceImageOrder.findIndex((name) => a.path.includes(name));
    const bIndex = mySpaceImageOrder.findIndex((name) => b.path.includes(name));
    const safeA = aIndex === -1 ? 999 : aIndex;
    const safeB = bIndex === -1 ? 999 : bIndex;
    return safeA - safeB;
  });

const isMySpace = slug === 'my-space-online';
const isKeepDM = slug === 'keepdm';
const isWLuna = slug === 'w-luna';
const isElectronicBilling = slug === 'electronic-billing-module';

const keepDmImages = Object.entries(keepDmImageModules).map(([path, src]) => {
  const image = src as string | AssetImage;
  return {
    path,
    src: typeof image === 'string' ? image : image.src,
  };
});

const keepDmLogo = keepDmImages.find((img) => img.path.includes('keepdm-logo_'));
const keepDmDashboard = keepDmImages.find((img) => img.path.includes('keepdm-dashboard_'));

const wLunaImages = Object.entries(wLunaImageModules).map(([path, src]) => {
  const image = src as string | AssetImage;
  return {
    path,
    src: typeof image === 'string' ? image : image.src,
  };
});

const wLunaLogo = wLunaImages.find((img) => img.path.includes('w-luna-logo'));
const wLunaImageOrder = ['w-luna-factura.webp', 'w-luna-main.webp', 'w-luna-registro.webp'];
const wLunaCaptions: Record<string, string> = {
  'w-luna-factura.webp': 'Factura electronica y ticket impreso generados directamente desde la operacion del parqueadero.',
  'w-luna-main.webp': 'Panel principal con flujo vehicular, ocupacion activa e indicadores operativos en tiempo real.',
  'w-luna-registro.webp': 'Pantalla de registro de ingreso con vista previa del ticket y captura de datos del cliente.',
};

const wLunaShowcaseImages = wLunaImages
  .filter((img) => wLunaImageOrder.some((name) => img.path.includes(name)))
  .sort((a, b) => {
    const aIndex = wLunaImageOrder.findIndex((name) => a.path.includes(name));
    const bIndex = wLunaImageOrder.findIndex((name) => b.path.includes(name));
    return aIndex - bIndex;
  });

const facturacionImages = Object.entries(facturacionImageModules).map(([path, src]) => {
  const image = src as string | AssetImage;
  return {
    path,
    src: typeof image === 'string' ? image : image.src,
  };
});

const alanubeLogo = facturacionImages.find((img) => img.path.includes('alanube-logo.svg'));
---

<Layout title={`${project.name} - ${content.meta.title}`}>
  <Navbar client:load content={content.nav} lang="es" />

  <main class="py-20 bg-white dark:bg-black transition-colors duration-300 min-h-screen">
    <section class="container mx-auto px-6 max-w-5xl">
      <a href="/es/projects" class="inline-flex items-center text-sm font-semibold text-neon hover:underline mb-8">
        Volver a todos los proyectos
      </a>

      {isKeepDM && keepDmLogo && (
        <section class="mb-8 flex justify-center">
          <img
            src={keepDmLogo.src}
            alt="Logo de KeepDM"
            class="object-cover rounded-3xl cursor-zoom-in"
            data-modal-image
            style="width: 128px; height: 128px;"
            loading="lazy"
          />
        </section>
      )}

      {isWLuna && wLunaLogo && (
        <section class="mb-8 flex justify-center">
          <img
            src={wLunaLogo.src}
            alt="Logo de W-luna"
            class="h-auto cursor-zoom-in"
            data-modal-image
            style="width: 220px;"
            loading="lazy"
          />
        </section>
      )}

      <header class="mb-10">
        <h1 class="text-4xl md:text-5xl font-bold text-black dark:text-white mb-4">{project.name}</h1>
        <p class="text-gray-700 dark:text-gray-300 text-lg mb-3">{details.headline}</p>
        <p class="text-gray-600 dark:text-gray-400">{project.details}</p>
      </header>

      <section class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Proposito</h2>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{details.purpose}</p>
      </section>

      <section class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Resumen</h2>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{details.overview}</p>
      </section>

      {isElectronicBilling && alanubeLogo && (
        <section class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Aliado Estrategico</h2>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6">
            Desarrollamos el Modulo de Facturacion Electronica junto a nuestro aliado estrategico Alanube, combinando conocimiento de negocio y ejecucion tecnica para una integracion DIAN confiable.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-5 sm:gap-8">
            <img src="/logo.webp" alt="Logo de SOSWER" class="w-auto cursor-zoom-in" data-modal-image style="height: 56px;" loading="lazy" />
            <span class="text-2xl font-extrabold text-neon"> x </span>
            <img src={alanubeLogo.src} alt="Logo de Alanube" class="w-auto cursor-zoom-in" data-modal-image style="height: 56px;" loading="lazy" />
          </div>
        </section>
      )}

      {details.about && (
        <section class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{details.aboutTitle}</h2>
          <div class="space-y-4">
            {details.about.map((paragraph: string) => (
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{paragraph}</p>
            ))}
          </div>
        </section>
      )}

      {isMySpace && mySpaceImages.length > 0 && (
        <section class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">{details.galleryTitle}</h2>
          <div class="space-y-6">
            {mySpaceImages.map((image, idx) => (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 items-center">
                {idx % 2 === 0 ? (
                  <>
                    <img
                      src={image.src}
                      alt={`Captura de My Space Online ${idx + 1}`}
                      class="w-full h-56 sm:h-64 object-cover rounded-xl cursor-zoom-in"
                      data-modal-image
                      loading="lazy"
                    />
                    <div class="rounded-xl p-4">
                      <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed">
                        {mySpaceImageOrder.find((name) => image.path.includes(name))
                          ? mySpaceCaptions[mySpaceImageOrder.find((name) => image.path.includes(name))!]
                          : `Muestra visual My Space Online ${idx + 1}.`}
                      </p>
                    </div>
                  </>
                ) : (
                  <>
                    <div class="rounded-xl p-4 md:order-1 order-2">
                      <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed">
                        {mySpaceImageOrder.find((name) => image.path.includes(name))
                          ? mySpaceCaptions[mySpaceImageOrder.find((name) => image.path.includes(name))!]
                          : `Muestra visual My Space Online ${idx + 1}.`}
                      </p>
                    </div>
                    <img
                      src={image.src}
                      alt={`Captura de My Space Online ${idx + 1}`}
                      class="w-full h-56 sm:h-64 object-cover rounded-xl md:order-2 order-1 cursor-zoom-in"
                      data-modal-image
                      loading="lazy"
                    />
                  </>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {isWLuna && wLunaShowcaseImages.length > 0 && (
        <section class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 mb-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Pantallas de W-luna</h2>
          <div class="space-y-6">
            {wLunaShowcaseImages.map((image, idx) => (
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 items-center">
                <img
                  src={image.src}
                  alt={`Pantalla W-luna ${idx + 1}`}
                  class="w-full h-64 sm:h-72 object-cover rounded-xl cursor-zoom-in"
                  data-modal-image
                  loading="lazy"
                />
                <div class="rounded-xl p-4">
                  <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed">
                    {wLunaImageOrder.find((name) => image.path.includes(name))
                      ? wLunaCaptions[wLunaImageOrder.find((name) => image.path.includes(name))!]
                      : `Visual W-luna ${idx + 1}.`}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">{details.impactTitle}</h2>
        <ul class="space-y-3">
          {details.impact.map((point: string) => (
            <li class="text-gray-700 dark:text-gray-300 flex items-start gap-3">
              <span class="text-neon mt-1">•</span>
              <span>{point}</span>
            </li>
          ))}
        </ul>
      </section>

      {isKeepDM && keepDmDashboard && (
        <section class="mt-8">
          <img
            src={keepDmDashboard.src}
            alt="Dashboard de KeepDM"
            class="w-full h-auto rounded-2xl cursor-zoom-in"
            data-modal-image
            loading="lazy"
          />
        </section>
      )}

      <div id="project-image-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 dark:bg-black/90 p-4 backdrop-blur-sm">
        <div class="bg-gray-100 dark:bg-black border-2 border-gray-400 dark:border-neon/50 shadow-xl dark:shadow-[0_0_20px_rgba(57,255,20,0.2)] max-w-[95vw] max-h-[90vh] flex flex-col overflow-hidden rounded-xl transition-colors duration-300">
          <div class="bg-gray-200 dark:bg-gray-900 border-b border-gray-400 dark:border-neon/30 text-gray-700 dark:text-neon px-3 py-1.5 flex items-center justify-between select-none transition-colors duration-300">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-neon rounded-full animate-pulse"></div>
              <span class="text-[10px] font-pixel tracking-wider uppercase">Visor_de_Imágenes.exe</span>
            </div>
            <div class="flex gap-2">
              <button id="project-image-modal-min" type="button" class="group w-5 h-5 border border-gray-400 dark:border-neon/30 flex items-center justify-center hover:bg-neon/10 hover:border-neon transition-colors cursor-pointer" title="Minimizar">
                <svg width="8" height="2" viewBox="0 0 8 2" fill="none" xmlns="http://www.w3.org/2000/svg" style="shape-rendering: crispEdges;">
                  <rect width="8" height="2" class="fill-gray-700/70 dark:fill-neon/70 group-hover:fill-neon"/>
                </svg>
              </button>
              <button id="project-image-modal-close" type="button" class="group w-5 h-5 border border-gray-400 dark:border-neon/30 flex items-center justify-center hover:bg-red-500/20 hover:border-red-500 transition-colors cursor-pointer" title="Cerrar">
                <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg" style="shape-rendering: crispEdges;">
                  <path d="M1 1H2V2H3V3H5V2H6V1H7V2H6V3H5V5H6V6H7V7H6V6H5V5H3V6H2V7H1V6H2V5H3V3H2V2H1V1Z" class="fill-gray-700/70 dark:fill-neon/70 group-hover:fill-red-500"/>
                </svg>
              </button>
            </div>
          </div>
          <div class="p-2 bg-gray-100 dark:bg-black flex items-center justify-center overflow-hidden transition-colors duration-300">
            <div class="border border-gray-300 dark:border-neon/10 p-1 bg-gray-200 dark:bg-gray-900/50">
              <img id="project-image-modal-img" src="" alt="Imagen ampliada del proyecto" class="max-w-full max-h-[75vh] object-contain" />
            </div>
          </div>
          <div class="bg-gray-200 dark:bg-gray-900 border-t border-gray-400 dark:border-neon/20 px-3 py-1.5 flex items-center transition-colors duration-300">
            <div class="text-[8px] font-pixel text-gray-700/50 dark:text-neon/50 uppercase tracking-tighter">Estado: En línea // Renderizado_Completo</div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const modal = document.getElementById('project-image-modal');
      const modalImg = document.getElementById('project-image-modal-img');
      const closeBtn = document.getElementById('project-image-modal-close');
      const minBtn = document.getElementById('project-image-modal-min');
      if (!modal || !modalImg || !closeBtn || !minBtn) return;

      const openModal = (src, alt) => {
        modalImg.src = src;
        modalImg.alt = alt || 'Imagen ampliada del proyecto';
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
      };

      const closeModal = () => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        modalImg.src = '';
        document.body.style.overflow = '';
      };

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const image = target.closest('img[data-modal-image]');
        if (image) {
          openModal(image.getAttribute('src') || '', image.getAttribute('alt') || 'Imagen ampliada del proyecto');
          return;
        }

        if (target === modal || target.closest('#project-image-modal-close') || target.closest('#project-image-modal-min')) {
          closeModal();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
          closeModal();
        }
      });
    })();
  </script>

  <Footer client:visible content={content.footer} />
</Layout>
