---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { translations } from '../../data/translations';

const content = translations.en;
const projects = content.projectsPage;
---

<Layout title={`Projects - ${content.meta.title}`}>
  <Navbar client:load content={content.nav} lang="en" />

  <main class="py-20 bg-white dark:bg-black transition-colors duration-300 min-h-screen">
    <section class="container mx-auto px-6">
      <div class="text-center mb-14">
        <h1 class="text-4xl md:text-6xl font-bold mb-4 text-black dark:text-white">
          {projects.title} <span class="text-neon">{projects.titleHighlight}</span>
        </h1>
        <p class="text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
          {projects.subtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {projects.items.map((project) => (
          <article class="rounded-2xl p-8 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 hover:border-neon/40 transition-all duration-300">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">{project.name}</h2>
            <p class="text-gray-700 dark:text-gray-300 mb-3">{project.summary}</p>
            <p class="text-gray-600 dark:text-gray-400 mb-6">{project.details}</p>

            <div class="flex flex-wrap gap-2">
              {project.stack.map((tech) => (
                <span class="px-3 py-1 text-xs font-medium text-neon bg-neon/10 rounded-full border border-neon/20">
                  {tech}
                </span>
              ))}
            </div>

            <a href={`/projects/${project.slug}`} class="inline-flex mt-6 text-sm font-semibold text-neon hover:underline">
              {projects.viewProject}
            </a>
          </article>
        ))}
      </div>

      <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-6 text-center">
        <a href="/" class="inline-flex items-center px-8 py-4 rounded-xl border border-neon/30 bg-neon/5 text-neon font-bold hover:bg-neon/10 transition-all transform hover:scale-105">
          {projects.backToHome}
        </a>
        <a href="/contact" class="inline-flex items-center px-8 py-4 rounded-xl bg-neon text-black font-bold hover:bg-neon-hover transition-all transform hover:scale-105 shadow-[0_0_20px_rgba(57,255,20,0.4)]">
          {content.hero.primaryCta}
        </a>
      </div>
    </section>
  </main>

  <Footer client:visible content={content.footer} />
</Layout>
